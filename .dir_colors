# Bare entries for old dircolors without glob support
TERM xterm
TERM uxterm
# Glob patterns (GNU coreutils >= 8.10)
TERM xterm*
TERM screen*
TERM tmux*
TERM rxvt*
TERM linux*
TERM con*
TERM gnome*
TERM konsole*
TERM putty*
TERM ansi
TERM mach-color
TERM vt100
TERM color
NORMAL 0
FILE 0
RESET 0
DIR 1
LINK 35
SOCK 1;44;37
FIFO 44;37
EXEC 32
BLK 46;34
CHR 47;34
SETUID 43;30
SETGID 43;30
STICKY_OTHER_WRITABLE 1;47;30
OTHER_WRITABLE       1;47;31
ORPHAN 41;37
MISSING 1;41;37
DOOR 44;37
CAPABILITY 31
MULTIHARDLINK 4
