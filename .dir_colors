# Bare entries for old dircolors without glob support
TERM xterm
TERM uxterm
# Glob patterns (GNU coreutils >= 8.10)
TERM xterm*
TERM screen*
TERM tmux*
TERM rxvt*
TERM linux*
TERM con*
TERM gnome*
TERM konsole*
TERM putty*
TERM ansi
TERM mach-color
TERM vt100
TERM color
NORMAL 0
RESET 0
FILE 0
DIR 1;94
EXEC 1
LINK 4;36
ORPHAN 4;41;37
MISSING 41;37
FIFO 44;37
SOCK 1;44;37
DOOR 44;37
BLK 46;34
CHR 47;34
SETUID 43;31
SETGID 43;31
STICKY_OTHER_WRITABLE 1;47;30
OTHER_WRITABLE 1;47;31
CAPABILITY 33
MULTIHARDLINK 4
