#!/bin/bash
# This scripts checks whether certain configuration files are reading
# globally shared configuration files. Run `link_files` first. The
# output is just shell commands to modify the files, nothing is done
# automatically.

gitconfig=".gitconfig_shared"
if [ -e "$HOME/$gitconfig" ]; then
    if ! grep -F "path = $gitconfig" -q "$HOME/.gitconfig"; then
        cat <<EOFGIT
# $gitconfig

git config --global --add include.path $gitconfig

EOFGIT
    fi
fi

sshconfig="config_shared"
sshpath="$HOME/.ssh"
if [ -e "$sshpath/$sshconfig" ]; then
    if ! grep -F "Include $sshconfig" -q "$sshpath/config"; then
        cat <<EOFSSH
# .ssh/$sshconfig

ex -sc '1i|Include $sshconfig' -cx ~/.ssh/config

EOFSSH
    fi
fi

kittyshared="kitty_shared.conf"
kittypath="$HOME/.config/kitty"
if [ -e "$kittypath/$kittyshared" ]; then
    if ! grep -F "include $kittyshared" -q "$kittypath/kitty.conf" 2>/dev/null; then
        cat <<EOFKITTY
# .config/kitty/$kittyshared

printf '\ninclude %s\n' '$kittyshared' >>"$kittypath/kitty.conf"

EOFKITTY
    fi
    if [ ! -e "$kittypath/light-theme.auto.conf" ]; then
        echo "n -s themes/Arkku.conf $kittypath/light-theme.auto.conf"
    fi
    if [ ! -e "$kittypath/no-preference-theme.auto.conf" ]; then
        echo "ln -s themes/Arkku.conf $kittypath/no-preference-theme.auto.conf"
    fi
    if [ ! -e "$kittypath/dark-theme.auto.conf" ]; then
        echo "ln -s "themes/Arkku Dark.conf" $kittypath/dark-theme.auto.conf"
    fi
fi

ghosttyshared="config_shared.ghostty"
ghosttypath="$HOME/.config/ghostty"
if [ -e "$ghosttypath/$ghosttyshared" ]; then
    ghosttymain=''
    for f in config.ghostty config; do
        if [ -e "$ghosttypath/$f" ]; then
            ghosttymain="$f"
            break
        fi
    done
    ghosttymain="${ghosttymain:-config.ghostty}"
    if ! grep -F "config-file = $ghosttyshared" -q "$ghosttypath/$ghosttymain" 2>/dev/null; then
        cat <<EOFGHOSTTY
# .config/ghostty/$ghosttyshared

printf '\nconfig-file = %s\ntheme = dark:Arkku Dark,light:Arkku\n' '$ghosttyshared' >>"$ghosttypath/$ghosttymain"

EOFGHOSTTY
    fi
fi

profile=".profile_shared"
if [ -e "$HOME/$profile" ]; then
    if ! grep -F '. "$HOME/'"$profile"'"' -q "$HOME/.profile"; then
        cat <<EOFPROFILE
# $profile

echo '. "\$HOME/$profile"' >>~/.profile

EOFPROFILE
    fi
    if ! grep -F '. "$HOME/'"$profile"'"' -q "$HOME/.zprofile" &&
       ! grep -F '. "$HOME/.profile"' -q "$HOME/.zprofile"; then
        cat <<EOFPROFILE
# $profile

echo '. "\$HOME/.profile"' >>~/.zprofile

EOFPROFILE
    fi
fi

