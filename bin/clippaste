#!/bin/sh
if [ -z "$SSH_CONNECTION" ] && [ -z "$OSC52" ]; then
    command -v pbpaste  >/dev/null 2>&1 && exec pbpaste
    if [ -n "$DISPLAY" ]; then
        command -v xclip >/dev/null 2>&1 && exec xclip -o -selection c
        command -v xsel  >/dev/null 2>&1 && exec xsel -o -b
    fi
    [ -r '/dev/clipboard' ]              && exec cat /dev/clipboard
fi

if [ -n "$TMUX" ]; then
    exec tmux save-buffer -
elif [ -n "$DISPLAY" ]; then
    command -v xclip >/dev/null 2>&1 && exec xclip -o -selection c
    command -v xsel  >/dev/null 2>&1 && exec xsel -o -b
fi
