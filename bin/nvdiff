#!/bin/sh
# dependencies: nvim
cmd=':DiffviewOpen'
case "$1" in
    --*)
        ;;
    main)
        cmd="$cmd origin/main...HEAD"
        shift
        ;;
    master)
        cmd="$cmd origin/master...HEAD"
        shift
        ;;
    *..*)
        cmd="$cmd $1"
        shift
        ;;
    [a-zA-Z]*)
        if [ ! -e "$1" ]; then
            cmd="$cmd $1"
            shift
        fi
        ;;
esac
exec nvim -c "$cmd" "$@"
