#!/usr/bin/env bash
if [ -z "$SSH_CONNECTION" ] && command -v pbcopy >/dev/null 2>&1; then
    exec pbcopy
elif [ -z "$SSH_CONNECTION" ] && command -v clip.exe >/dev/null 2>&1; then
    exec clip.exe
elif [ -n "$DISPLAY" ]; then
    if command -v xclip >/dev/null 2>&1; then
        exec xclip -selection c
    elif command -v xsel >/dev/null 2>&1; then
        exec xsel -i -b
    fi
elif [ -z "$SSH_CONNECTION" ]; then
    if command -v clip >/dev/null 2>&1; then
        exec clip
    elif [ -w '/dev/clipboard' ]; then
        exec cat >/dev/clipboard
    fi
fi

encode_osc52() {
    base64 | tr -d '\n\r'
}

if [ -n "$TMUX" ]; then
    set -- $(tmux display-message -p "#{client_tty} #{client_termname}")
    client_tty="$1"
    outer_term="$2"

    case "$outer_term" in
        tmux*|screen*)
            # Nested tmux needs passthrough
            if command -v base64 >/dev/null 2>&1; then
                echo nestedtmux >/tmp/clip
                exec printf "\033Ptmux;\033]52;c;%s\033\\\033\\" "$(encode_osc52)" >"${client_tty:-/dev/stdout}"
            else
                exec tmux load-buffer -
            fi
            ;;
        *)
            # Single layer of tmux, just use OSC 52
            if command -v base64 >/dev/null 2>&1; then
                echo "$outer_term" >/tmp/clip
                exec printf "\033]52;c;%s\033\\" "$(encode_osc52)" >"${client_tty:-/dev/stdout}"
            else
                exec tmux load-buffer -
            fi
            ;;
    esac

elif command -v base64 >/dev/null 2>&1; then
    exec printf "\033]52;c;%s\033\\" "$(encode_osc52)"
fi
