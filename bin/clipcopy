#!/usr/bin/env bash
if [ -z "$SSH_CONNECTION" -a -n "$(command -v pbcopy)" ]; then
    exec pbcopy
elif [ -z "$SSH_CONNECTION" -a -n "$(command -v clip.exe)" ]; then
    exec clip.exe
elif [ -n "$DISPLAY" ]; then
    if [ -n "$(command -v xclip)" ]; then
        exec xclip -selection c
    elif [ -n "$(command -v xsel)" ]; then
        exec xsel -i -b
    fi
elif [ -z "$SSH_CONNECTION" ]; then
    if [ -n "$(command -v clip)" ]; then
        exec clip
    elif [ -w '/dev/clipboard' ]; then
        exec cat >/dev/clipboard
    fi
fi
if [ -n "$TMUX" ]; then
    if [ -n "$(command -v base64)" ]; then
        exec printf "\033Ptmux;\033\033]52;c;%s\a\033\\" "$(base64 | tr -d '\n\r')"
    else
        exec tmux load-buffer -
    fi
elif [ -n "$(command -v base64)" ]; then
    exec printf "\033]52;c;%s\033\\" "$(base64 | tr -d '\n\r')"
fi
