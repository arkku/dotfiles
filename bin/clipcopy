#!/usr/bin/env bash
if [ -z "$SSH_CONNECTION" ] && command -v pbcopy >/dev/null 2>&1; then
    exec pbcopy
elif [ -z "$SSH_CONNECTION" ] && command -v clip.exe >/dev/null 2>&1; then
    exec clip.exe
elif [ -n "$DISPLAY" ]; then
    if command -v xclip >/dev/null 2>&1; then
        exec xclip -selection c
    elif command -v xsel >/dev/null 2>&1; then
        exec xsel -i -b
    fi
elif [ -z "$SSH_CONNECTION" ]; then
    if command -v clip >/dev/null 2>&1; then
        exec clip
    elif [ -w '/dev/clipboard' ]; then
        exec cat >/dev/clipboard
    fi
fi
if [ -n "$TMUX" ]; then
    if command -v base64 >/dev/null 2>&1; then
        exec printf "\033Ptmux;\033\033]52;c;%s\033\033\\\033\\" "$(base64 | tr -d '\n\r')"
    else
        exec tmux load-buffer -
    fi
elif command -v base64 >/dev/null 2>&1; then
    exec printf "\033]52;c;%s\033\\" "$(base64 | tr -d '\n\r')"
fi
