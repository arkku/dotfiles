#!/bin/sh

# Local clipboard tools — skipped if $OSC52 is set (terminal advertises OSC 52
# support) or in an SSH session, in which case OSC 52 is preferred.
if [ -z "$SSH_CONNECTION" ] && [ -z "$OSC52" ]; then
    command -v pbcopy   >/dev/null 2>&1 && exec pbcopy
    command -v clip.exe >/dev/null 2>&1 && exec clip.exe
    if [ -n "$DISPLAY" ]; then
        command -v xclip >/dev/null 2>&1 && exec xclip -selection c
        command -v xsel  >/dev/null 2>&1 && exec xsel -i -b
    fi
    command -v clip      >/dev/null 2>&1 && exec clip
    [ -w '/dev/clipboard' ]              && exec cat >/dev/clipboard
fi

# Output full OSC 52 sequence: ESC ] 52 ; c ; <base64> ST
encode_osc52() {
    printf '\033]52;c;%s\033\\' "$(base64 | tr -d '\n\r')"
}

if [ -n "$TMUX" ] && command -v tmux >/dev/null 2>&1; then
    if command -v base64 >/dev/null 2>&1; then
        set -- $(tmux display-message -p "#{client_tty} #{client_termname}")
        client_tty=$1

        case "$2" in
            tmux*|screen*)
                # Nested tmux: DCS passthrough with doubled ESC bytes
                # tmux un-doubles \033\033 → \033 when forwarding
                exec printf '\033Ptmux;\033\033]52;c;%s\033\033\\\033\\' \
                    "$(base64 | tr -d '\n\r')" >"${client_tty:-/dev/stdout}"
                ;;
            *)
                encode_osc52 >"${client_tty:-/dev/stdout}"
                ;;
        esac
    else
        exec tmux load-buffer -
    fi
elif command -v base64 >/dev/null 2>&1; then
    encode_osc52
fi
