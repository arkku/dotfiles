{
    "title": "Swap Left Ctrl and Apple Fn/Globe",
    "rules": [
        {
            "description": "Swap Left Ctrl and Fn on Apple keyboards",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "left_control",
                        "modifiers": { "optional": ["any"] }
                    },
                    "to": [{ "apple_vendor_top_case_key_code": "keyboard_fn" }],
                    "conditions": [{
                        "type": "device_if",
                        "identifiers": [
                            {
                                "vendor_id": 1452,
                                "is_keyboard": true
                            }
                        ]
                    }]
                },
                {
                    "type": "basic",
                    "from": {
                        "apple_vendor_top_case_key_code": "keyboard_fn",
                        "modifiers": { "optional": ["any"] }
                    },
                    "to": [ { "key_code": "left_control" }],
                    "conditions": [{
                        "type": "device_if",
                        "identifiers": [
                            {
                                "vendor_id": 1452,
                                "is_keyboard": true
                            }
                        ]
                    }]
                }
            ]
        },
        {
            "description": "Swap Left Ctrl and Fn (Internal keyboard only)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "left_control",
                        "modifiers": { "optional": ["any"] }
                    },
                    "to": [{ "apple_vendor_top_case_key_code": "keyboard_fn" }],
                    "conditions": [{
                        "type": "device_if",
                        "identifiers": [{ "is_built_in_keyboard": true }]
                    }]
                },
                {
                    "type": "basic",
                    "from": {
                        "apple_vendor_top_case_key_code": "keyboard_fn",
                        "modifiers": { "optional": ["any"] }
                    },
                    "to": [ { "key_code": "left_control" }],
                    "conditions": [{
                        "type": "device_if",
                        "identifiers": [{ "is_built_in_keyboard": true }]
                    }]
                }
            ]
        }
    ]
}
